# Required: DeepSeek API key (chat model)
DEEPSEEK_API=sk-your-key-here

# Required: Gemini API key (image analysis only)
GEMINI_API_KEY=your-gemini-key-here

# Required: Access code to protect the app (share with friends)
ACCESS_CODE=tu-codigo-secreto

# Optional: Cloudflare Tunnel token (for public hosting)
# Get this from: cloudflared tunnel create cobblemon-agent
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here
